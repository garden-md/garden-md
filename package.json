{
  "name": "garden-md",
  "version": "0.8.5",
  "description": "Turn your meeting transcripts into a Wikipedia for your company.",
  "bin": {
    "garden": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc && mkdir -p dist/connectors && cp src/connectors/*.mjs dist/connectors/",
    "dev": "tsc --watch",
    "start": "node dist/cli.js"
  },
  "keywords": [
    "wiki",
    "knowledge-base",
    "cli",
    "ai",
    "transcripts"
  ],
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@inquirer/prompts": "^8.3.2",
    "@types/node": "^25.5.0",
    "chalk": "^5.6.2",
    "cli-progress": "^3.12.0",
    "commander": "^14.0.3",
    "express": "^5.2.1",
    "inquirer": "^13.3.2",
    "marked": "^17.0.5",
    "openai": "^6.33.0",
    "ora": "^9.3.0",
    "typescript": "^6.0.2",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.6",
    "@types/express": "^5.0.6",
    "@types/inquirer": "^9.0.9",
    "vitest": "^4.1.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/garden-md/garden-md.git"
  },
  "homepage": "https://github.com/garden-md/garden-md#readme",
  "bugs": {
    "url": "https://github.com/garden-md/garden-md/issues"
  }
}
